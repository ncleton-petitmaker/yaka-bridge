# Supabase runtime configuration
# Public project URL, safe to expose to the renderer if needed.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key, safe for client-side/public operations guarded by RLS.
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key for daemon-side actions. Never expose this in the UI.
SUPABASE_SERVICE_ROLE_KEY=

# API mode:
# - local: Next rewrites /api/* to the local Hono daemon.
# - cloud: browser calls Supabase Edge Functions / cloud API with Supabase auth.
NEXT_PUBLIC_APP_API_MODE=local
NEXT_PUBLIC_CLOUD_API_URL=
NEXT_PUBLIC_DAEMON_PORT={{DAEMON_PORT}}

# Local bridge configuration. The bridge polls the cloud API and executes jobs
# on this workstation with the same local agentic engine as Electron.
BRIDGE_CONTROL_PLANE_URL=
BRIDGE_ORGANIZATION_ID=
BRIDGE_TOKEN=
BRIDGE_ID=
BRIDGE_CONFIG=
BRIDGE_DATA_DIR=

# Supabase CLI / Management API token.
# Use only in your local shell or CI secret store, never in app-config.json.
SUPABASE_ACCESS_TOKEN=
