{
  "name": "yaka-bridge",
  "version": "0.0.43",
  "private": true,
  "description": "Template yaka-bridge pour ERP cloud modulaire avec Supabase, Bridge local, MCP et workflows agentiques.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "{{APP_ID}}",
    "productName": "{{APP_NAME}}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "dist/**",
      ".next/standalone/**",
      "skills-template/**",
      "data-template/**"
    ],
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "files": [
      "electron/**/*",
      "dist/**/*",
      ".next/standalone/**/*",
      "public/**/*",
      "skills-template/**/*",
      "data-template/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone/.next/static",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "public/icon-512.png",
      "target": [
        "nsis"
      ],
      "artifactName": "{{APP_NAME}}-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "linux": {
      "icon": "public/icon-512.png"
    }
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start:daemon": "tsx server/index.ts",
    "start:next": "next start -p {{NEXT_PORT}}",
    "start": "node scripts/start.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "security:grep": "node scripts/security-grep.mjs",
    "factory:check": "node scripts/factory-check.mjs",
    "deploy-data": "node scripts/postinstall.mjs",
    "lint": "next lint",
    "electron": "electron electron/main.cjs",
    "electron:pack:mac": "node scripts/prepare-pack.mjs && electron-builder --mac",
    "electron:pack:win": "node scripts/prepare-pack.mjs && electron-builder --win --x64 --config.npmRebuild=false",
    "bridge": "tsx bridge/index.ts",
    "bridge:install": "tsx bridge/install.ts",
    "bridge:build": "node scripts/build-bridge.mjs",
    "bridge:pack:mac": "npm run bridge:build && electron-builder --mac --config electron-builder.bridge.cjs",
    "bridge:pack:win": "npm run bridge:build && electron-builder --win --x64 --config electron-builder.bridge.cjs --config.npmRebuild=false",
    "dev:local": "node scripts/dev.mjs",
    "dev:cloud": "NEXT_PUBLIC_APP_API_MODE=cloud next dev -p {{NEXT_PORT}}",
    "start:mcp": "tsx server/mcp.ts",
    "brand:icons": "node scripts/brand-icons.mjs",
    "bridge:token": "node scripts/create-bridge-token.mjs"
  },
  "dependencies": {
    "@openreplay/tracker": "^18.0.14",
    "@supabase/supabase-js": "^2.108.1",
    "electron-updater": "^6.8.9",
    "react-resizable-panels": "^4.11.2"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "hono": "^4.12.25",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.7"
  }
}
