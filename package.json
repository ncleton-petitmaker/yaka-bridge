{
  "name": "yaka-bridge",
  "version": "0.0.48",
  "private": true,
  "description": "Template yaka-bridge pour ERP cloud modulaire avec Supabase, Bridge local, MCP et workflows agentiques.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "templates/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "{{APP_ID}}",
    "productName": "{{APP_NAME}}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "dist/**",
      ".next/standalone/**",
      "skills-template/**",
      "data-template/**"
    ],
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "files": [
      "electron/**/*",
      "dist/**/*",
      ".next/standalone/**/*",
      "public/**/*",
      "skills-template/**/*",
      "data-template/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone/.next/static",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "public/icon-512.png",
      "target": [
        "nsis"
      ],
      "artifactName": "{{APP_NAME}}-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "linux": {
      "icon": "public/icon-512.png"
    }
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start:daemon": "tsx server/index.ts",
    "start:next": "node scripts/start-next.mjs",
    "start": "node scripts/start.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "security:grep": "node scripts/security-grep.mjs",
    "skills:sync": "node scripts/sync-codex-skills.mjs",
    "skills:check": "node scripts/sync-codex-skills.mjs --check",
    "codex:onboard": "node scripts/codex-onboard.mjs",
    "codex:onboard:prompt": "node scripts/codex-onboard.mjs --print",
    "projects:list": "node scripts/projects.mjs list",
    "projects:check": "node scripts/projects.mjs check",
    "projects:init": "node scripts/projects.mjs init",
    "yaka:doctor": "node scripts/yaka-sync-guardian.mjs doctor --strict",
    "yaka:status": "node scripts/yaka-sync-guardian.mjs status",
    "yaka:clients": "node scripts/yaka-sync-guardian.mjs clients",
    "yaka:pack:packages": "node scripts/publish-yaka-packages.mjs --dry-run",
    "yaka:publish:packages": "node scripts/publish-yaka-packages.mjs",
    "factory:check": "node scripts/factory-check.mjs",
    "deploy-data": "node scripts/postinstall.mjs",
    "lint": "next lint",
    "electron": "electron electron/main.cjs",
    "electron:pack:mac": "node scripts/prepare-pack.mjs && electron-builder --mac",
    "electron:pack:win": "node scripts/prepare-pack.mjs && electron-builder --win --x64 --config.npmRebuild=false",
    "bridge": "tsx bridge/index.ts",
    "bridge:install": "tsx bridge/install.ts",
    "bridge:build": "node scripts/build-bridge.mjs",
    "bridge:verify-assets": "node scripts/verify-bridge-package-assets.mjs",
    "smoke:lmstudio": "node scripts/smoke-lmstudio.mjs",
    "bridge:pack:mac": "node scripts/yaka-sync-guardian.mjs doctor --strict --allow-platform-build && node scripts/build-bridge.mjs --target darwin --require-voice-sidecar && electron-builder --mac --config electron-builder.bridge.cjs",
    "bridge:pack:win": "node scripts/yaka-sync-guardian.mjs doctor --strict --allow-platform-build && node scripts/build-bridge.mjs --target win32 --require-voice-sidecar && electron-builder --win --x64 --config electron-builder.bridge.cjs --config.npmRebuild=false",
    "design:apply": "node scripts/apply-design-system.mjs",
    "design:import": "node scripts/import-design-system.mjs",
    "dev:local": "node scripts/dev.mjs",
    "dev:cloud": "NEXT_PUBLIC_APP_API_MODE=cloud next dev -p {{NEXT_PORT}}",
    "start:mcp": "tsx server/mcp.ts",
    "brand:icons": "node scripts/brand-icons.mjs",
    "bridge:token": "node scripts/create-bridge-token.mjs"
  },
  "dependencies": {
    "@openreplay/tracker": "^18.0.13",
    "@supabase/supabase-js": "^2.107.0",
    "electron-updater": "^6.8.9",
    "react-resizable-panels": "^2.1.9",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.4",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.184.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.1",
    "hono": "^4.12.25",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.7"
  }
}
