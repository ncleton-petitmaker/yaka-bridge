{
  "name": "bridge-erp-template",
  "version": "0.0.28",
  "private": true,
  "description": "Template Bridge + Supabase self-hosted pour ERP modulaire multi-services.",
  "engines": {
    "node": ">=24"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "{{APP_ID}}",
    "productName": "{{APP_NAME}}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "dist/**",
      ".next/standalone/**",
      "skills-template/**",
      "data-template/**"
    ],
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "files": [
      "electron/**/*",
      "dist/**/*",
      ".next/standalone/**/*",
      "public/**/*",
      "skills-template/**/*",
      "data-template/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone/.next/static",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "public/icon-512.png",
      "target": [
        "nsis"
      ],
      "artifactName": "{{APP_NAME}}-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "linux": {
      "icon": "public/icon-512.png"
    }
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "concurrently -n daemon,next -c blue,green \"tsx watch server/index.ts\" \"next dev -p {{NEXT_PORT}}\"",
    "build": "next build",
    "start:daemon": "tsx server/index.ts",
    "start:next": "next start -p {{NEXT_PORT}}",
    "start": "node scripts/start.js",
    "typecheck": "tsc --noEmit",
    "deploy-data": "node scripts/postinstall.js",
    "lint": "next lint",
    "electron": "electron electron/main.cjs",
    "electron:pack:mac": "node scripts/prepare-pack.mjs && electron-builder --mac",
    "electron:pack:win": "node scripts/prepare-pack.mjs && electron-builder --win --x64 --config.npmRebuild=false",
    "bridge": "tsx bridge/index.ts",
    "bridge:install": "tsx bridge/install.ts",
    "bridge:build": "node scripts/build-bridge.mjs",
    "bridge:pack:mac": "npm run bridge:build && electron-builder --mac --config electron-builder.bridge.cjs",
    "bridge:pack:win": "npm run bridge:build && electron-builder --win --x64 --config electron-builder.bridge.cjs --config.npmRebuild=false",
    "dev:local": "concurrently -n daemon,next -c blue,green \"tsx watch server/index.ts\" \"next dev -p {{NEXT_PORT}}\"",
    "dev:cloud": "NEXT_PUBLIC_APP_API_MODE=cloud next dev -p {{NEXT_PORT}}",
    "start:mcp": "tsx server/mcp.ts",
    "brand:icons": "node scripts/brand-icons.mjs"
  },
  "dependencies": {
    "@openreplay/tracker": "^18.0.13",
    "@supabase/supabase-js": "^2.107.0",
    "electron-updater": "^6.8.9",
    "react-resizable-panels": "^2.1.9"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.2",
    "hono": "^4.6.14",
    "next": "^16.0.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  }
}
