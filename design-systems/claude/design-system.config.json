    "--fg",
    "--fg-strong",
    "--muted",
    "--soft",
    "--faint",
    "--accent",
    "--accent-strong",
    "--accent-soft",
    "--accent-tint",
    "--accent-hover",
    "--green",
    "--green-bg",
    "--green-border",
    "--blue",
    "--blue-bg",
    "--blue-border",
    "--purple",
