{
  "contractVersion": "1.0.0",
  "id": "claude",
  "name": "Claude",
  "version": "1.0.0",
  "description": "Warm, quiet, production-focused ERP design system inspired by Claude desktop/product surfaces.",
  "sourceKind": "built-in",
  "targets": ["app", "modules", "bridge"],
  "files": {
    "tokens": "tokens.css",
    "designDoc": "DESIGN.md",
    "appMark": "assets/app-mark.svg",
    "bridgeMark": "assets/bridge-mark.svg"
  },
  "tailwind": {
    "usesCssVariables": true,
    "tokenPrefix": "--"
  },
  "bridge": {
    "tokens": {
      "bg": "#faf9f7",
      "panel": "#ffffff",
      "border": "#ebe8e1",
      "text": "#1a1916",
      "muted": "#746f66",
      "soft": "#9b958c",
      "accent": "#c96442",
      "accentTint": "#f0efeb",
      "green": "#2e7d32",
      "greenBg": "#eef8ef",
      "red": "#b23b2d",
      "redBg": "#fff0ee",
      "secondary": "#ebe8e1",
      "logBg": "#f4f2ed",
      "logoText": "B"
    }
  },
  "requiredCssVariables": [
