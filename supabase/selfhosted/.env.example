SUPABASE_DOMAIN=api.customer.example
API_EXTERNAL_URL=https://api.customer.example
SITE_URL=https://erp.customer.example
ADDITIONAL_REDIRECT_URLS=https://erp.customer.example/**,https://admin.customer.example/**

POSTGRES_PASSWORD=generate-a-long-random-value
JWT_SECRET=generate-at-least-32-random-bytes
ANON_KEY=generate-from-jwt-secret
SERVICE_ROLE_KEY=generate-from-jwt-secret
SECRET_KEY_BASE=generate-a-long-random-value
VAULT_ENC_KEY=generate-exactly-32-characters
REALTIME_DB_ENC_KEY=generate-a-long-random-value

GOTRUE_DISABLE_SIGNUP=true
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_SMTP_HOST=smtp.customer.example
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=smtp-user
GOTRUE_SMTP_PASS=smtp-password
GOTRUE_SMTP_ADMIN_EMAIL=no-reply@customer.example
GOTRUE_SMTP_SENDER_NAME=Bridge

STORAGE_FILE_SIZE_LIMIT=268435456
